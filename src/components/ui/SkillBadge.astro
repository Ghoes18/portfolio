---
interface Props {
  name: string;
  highlighted?: boolean;
}

const { name, highlighted = false } = Astro.props;

const classes = highlighted
  ? "bg-accent text-accent-foreground rounded-full px-4 py-2 text-sm font-medium"
  : "bg-secondary text-secondary-foreground border border-border rounded-full px-4 py-2 text-sm font-medium";
---

<span class={classes}>
  {name}
</span>
