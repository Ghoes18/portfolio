---
import Button from "../ui/Button.astro";

const contactLinks = [
  {
    label: "Email",
    href: "mailto:goncaloguimaraes@protonmail.com",
    value: "goncaloguimaraes@protonmail.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    label: "GitHub",
    href: "https://github.com/Ghoes18",
    value: "github.com/Ghoes18",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/goncaloguimaraes",
    value: "linkedin.com/in/goncaloguimaraes",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    label: "Phone",
    href: "tel:+351925698714",
    value: "+351 925 698 714",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  },
];
---

<section id="contact" class="border-t border-border px-6 py-24 md:px-12" aria-labelledby="contact-heading">
  <div class="mx-auto max-w-5xl">
    <div class="text-center mb-16">
      <p id="contact-heading" class="text-label mb-6 uppercase tracking-wider text-muted-foreground">Contact</p>
      <h2 class="text-display mb-8 font-black uppercase leading-none text-foreground">
        <span class="block">LET'S BUILD</span>
        <span class="block">SOMETHING.</span>
      </h2>
      <p class="text-body mb-10 max-w-xl mx-auto text-muted-foreground">
        Open to full-time and contract roles. Happy to discuss fit and how I can contribute to your team.
      </p>
      <Button href="mailto:goncaloguimaraes@protonmail.com" variant="primary">
        Start a project →
      </Button>
    </div>

    <!-- Contact Links Grid -->
    <div class="border-t border-border pt-12">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {contactLinks.map((link) => (
          <a 
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="group flex items-start gap-3 rounded-lg border border-border bg-card p-4 transition-colors hover:border-accent hover:bg-card/80"
          >
            <span class="text-muted-foreground group-hover:text-accent transition-colors mt-0.5" set:html={link.icon} />
            <div class="min-w-0 flex-1">
              <span class="text-label block uppercase tracking-wider text-muted-foreground text-xs">{link.label}</span>
              <span class="text-sm font-medium text-foreground group-hover:text-accent transition-colors break-all block leading-tight">
                {link.value}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Location -->
    <div class="mt-12 text-center">
      <p class="text-body-sm text-muted-foreground">
        Based in Santa Maria da Feira, Portugal · Available for remote work worldwide
      </p>
    </div>
  </div>
</section>
