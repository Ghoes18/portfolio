---
const tickerItems = "VIXELLIA · HERCOLES · STREAMERDONATIONS · AGENDAPRO · JUIZ.AI · MEDIA-LOG";
---

<section class="relative flex min-h-screen flex-col justify-end px-6 pb-24 pt-28 md:px-12 md:pt-36" aria-label="Hero">
  <div class="flex flex-1 flex-col justify-center">
    <h1 class="text-display font-black uppercase leading-none text-foreground">
      <span class="block">GONÇALO</span>
      <span class="block">GUIMARÃES</span>
    </h1>
    <hr class="my-8 w-full border-border" />
    <div class="grid gap-8 md:grid-cols-2 md:gap-16">
      <p class="text-body text-muted-foreground">
        SaaS Architect & Full-Stack Engineer · Santa Maria da Feira, Portugal
      </p>
      <p class="text-body text-muted-foreground">
        From idea to live product. I ship the full stack so you don't have to. AI platforms, real-time systems, payments. 6 products built and deployed, solo.
      </p>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 overflow-hidden border-t border-border py-4">
    <div class="flex w-max animate-marquee gap-8 whitespace-nowrap text-label font-medium uppercase tracking-wider text-accent">
      <span aria-hidden="true">{tickerItems}</span>
      <span aria-hidden="true">{tickerItems}</span>
    </div>
  </div>
</section>
